<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="15" xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="org.example.controllers.UserController">

    <padding>
        <Insets top="20" right="20" bottom="20" left="20"/>
    </padding>

    <Label text="👤 Détails utilisateur" style="-fx-font-size: 24px; -fx-font-weight: bold;"/>

    <Label fx:id="emailLabel" text="Email :"/>
    <Label fx:id="nomCompletLabel" text="Nom complet :"/>
    <Label fx:id="telephoneLabel" text="Téléphone :"/>
    <Label fx:id="typeLabel" text="Type :"/>
    <Label fx:id="rolesLabel" text="Rôles :"/>
    <Label fx:id="createdAtLabel" text="Créé le :"/>

    <HBox spacing="10">
        <Button text="← Retour" onAction="#handleBack"/>
        <Button text="✏ Modifier" onAction="#handleEditUser"/>
        <Button text="🗑 Supprimer" onAction="#handleDeleteUser"
                style="-fx-background-color: #dc3545; -fx-text-fill: white;"/>
    </HBox>
</VBox>