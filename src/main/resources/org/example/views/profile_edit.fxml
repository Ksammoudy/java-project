<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane fx:id="rootPane"
            xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="org.example.controllers.ProfileController"
            prefWidth="1200.0" prefHeight="750.0"
            styleClass="citizen-root"
            stylesheets="@../styles/style.css">

    <center>
        <VBox spacing="20.0" styleClass="citizen-main">
            <padding>
                <Insets top="30.0" right="30.0" bottom="30.0" left="30.0"/>
            </padding>

            <HBox spacing="20.0" alignment="CENTER_LEFT">
                <VBox spacing="5.0">
                    <Label text="✏ Modifier mon profil" styleClass="citizen-h1"/>
                    <Label text="Mets à jour tes informations et ton mot de passe" styleClass="citizen-sub"/>
                </VBox>

                <Region HBox.hgrow="ALWAYS"/>
            </HBox>

            <VBox spacing="18.0" styleClass="citizen-card2">
                <Label text="Formulaire" styleClass="citizen-card-title"/>

                <HBox spacing="16.0">
                    <VBox spacing="6.0" HBox.hgrow="ALWAYS">
                        <Label text="Nom" styleClass="field-label"/>
                        <TextField fx:id="nomField" promptText="Nom" styleClass="input-field"/>
                    </VBox>

                    <VBox spacing="6.0" HBox.hgrow="ALWAYS">
                        <Label text="Prénom" styleClass="field-label"/>
                        <TextField fx:id="prenomField" promptText="Prénom" styleClass="input-field"/>
                    </VBox>
                </HBox>

                <HBox spacing="16.0">
                    <VBox spacing="6.0" HBox.hgrow="ALWAYS">
                        <Label text="Téléphone" styleClass="field-label"/>
                        <TextField fx:id="telephoneField" promptText="Téléphone" styleClass="input-field"/>
                    </VBox>

                    <VBox spacing="6.0" HBox.hgrow="ALWAYS">
                        <Label text="Email" styleClass="field-label"/>
                        <TextField fx:id="emailField" promptText="Email" styleClass="input-field"/>
                    </VBox>
                </HBox>

                <VBox spacing="14.0" styleClass="small-box">
                    <Label text="🔐 Sécurité" styleClass="small-box-title"/>

                    <VBox spacing="6.0">
                        <Label text="Mot de passe actuel" styleClass="field-label"/>
                        <PasswordField fx:id="currentPasswordField"
                                       promptText="Mot de passe actuel"
                                       styleClass="input-field"/>
                    </VBox>

                    <HBox spacing="16.0">
                        <VBox spacing="6.0" HBox.hgrow="ALWAYS">
                            <Label text="Nouveau mot de passe" styleClass="field-label"/>
                            <PasswordField fx:id="newPasswordField"
                                           promptText="Nouveau mot de passe"
                                           styleClass="input-field"/>
                        </VBox>

                        <VBox spacing="6.0" HBox.hgrow="ALWAYS">
                            <Label text="Confirmer le nouveau mot de passe" styleClass="field-label"/>
                            <PasswordField fx:id="confirmPasswordField"
                                           promptText="Confirmation"
                                           styleClass="input-field"/>
                        </VBox>
                    </HBox>

                    <Label text="Laisse les champs vides si tu ne veux pas changer le mot de passe."
                           wrapText="true"
                           styleClass="citizen-note"/>
                </VBox>

                <Label fx:id="messageLabel"
                       text=""
                       wrapText="true"
                       styleClass="message-label"/>

                <HBox spacing="12.0">
                    <Button text="✔ Enregistrer"
                            onAction="#handleSaveProfile"
                            styleClass="btn-success"/>

                    <Button text="👤 Voir mon profil"
                            onAction="#handleViewProfilePage"
                            styleClass="citizen-action-btn"/>

                    <Button text="↩ Retour dashboard"
                            onAction="#handleBackToDashboard"
                            styleClass="citizen-action-btn"/>
                </HBox>
            </VBox>
        </VBox>
    </center>
</BorderPane>