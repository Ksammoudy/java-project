<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Priority?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="org.example.controllers.UserController"
            prefWidth="1200.0" prefHeight="750.0"
            style="-fx-background-color: white;">

    <top>
        <VBox spacing="10" style="-fx-padding: 20;">
            <HBox spacing="10" alignment="CENTER_LEFT">
                <VBox spacing="4">
                    <Label text="👥 Utilisateurs"
                           style="-fx-font-size: 24px; -fx-font-weight: bold;"/>
                    <Label text="Gestion des comptes utilisateurs"
                           style="-fx-text-fill: #666666;"/>
                </VBox>

                <Region HBox.hgrow="ALWAYS"/>

                <Button text="➕ Créer"
                        onAction="#handleNewUser"
                        style="-fx-background-color: #0d6efd; -fx-text-fill: white; -fx-font-weight: bold;"/>
            </HBox>

            <Label fx:id="pageMessageLabel"
                   text=""
                   style="-fx-font-weight: bold;"/>

            <HBox spacing="10" alignment="CENTER_LEFT">
                <Label text="Total :" style="-fx-font-weight: bold;"/>
                <Label fx:id="totalUsersLabel" text="0"/>

                <Region HBox.hgrow="ALWAYS"/>

                <Button text="🔄 Actualiser" onAction="#handleRefreshUsers"/>
                <Button text="🔁 Activer / Désactiver" onAction="#handleToggleUser"/>
                <Button text="✏ Modifier" onAction="#handleEditUser"/>
                <Button text="🗑 Supprimer" onAction="#handleDeleteUser"/>
                <Button text="↩ Retour" onAction="#handleBackToAdminDashboard"/>
            </HBox>
        </VBox>
    </top>

    <center>
        <VBox style="-fx-padding: 0 20 20 20;">
            <TableView fx:id="usersTable" VBox.vgrow="ALWAYS">
                <columns>
                    <TableColumn fx:id="emailColumn" text="Email" prefWidth="250"/>
                    <TableColumn fx:id="fullNameColumn" text="Nom complet" prefWidth="220"/>
                    <TableColumn fx:id="phoneColumn" text="Téléphone" prefWidth="150"/>
                    <TableColumn fx:id="typeColumn" text="Type" prefWidth="150"/>
                    <TableColumn fx:id="statusColumn" text="Statut" prefWidth="140"/>
                    <TableColumn fx:id="createdAtColumn" text="Créé le" prefWidth="180"/>
                </columns>
            </TableView>
        </VBox>
    </center>

</BorderPane>