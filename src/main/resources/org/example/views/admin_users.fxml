<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="org.example.controllers.UserController"
            prefWidth="1200.0" prefHeight="750.0"
            styleClass="dashboard-root"
            stylesheets="@../styles/style.css">

    <top>
        <VBox spacing="18.0" styleClass="main-area">
            <padding>
                <Insets top="20.0" right="24.0" bottom="10.0" left="24.0"/>
            </padding>

            <HBox alignment="CENTER_LEFT" spacing="12.0" styleClass="top-header">
                <VBox spacing="4.0">
                    <Label text="👥 Utilisateurs" styleClass="page-title"/>
                    <Label text="Gestion des comptes utilisateurs" styleClass="page-subtitle"/>
                </VBox>

                <Region HBox.hgrow="ALWAYS"/>
            </HBox>

            <Label fx:id="pageMessageLabel"
                   text=""
                   wrapText="true"
                   styleClass="card-text"/>

            <HBox spacing="10.0" alignment="CENTER_LEFT">
                <Label text="Total :" styleClass="stat-label"/>
                <Label fx:id="totalUsersLabel" text="0" styleClass="stat-value-small"/>

                <Region HBox.hgrow="ALWAYS"/>

                <Button text="🔄 Actualiser"
                        onAction="#handleRefreshUsers"
                        styleClass="shortcut-btn"/>

                <Button text="🔁 Activer / Désactiver"
                        onAction="#handleToggleUser"
                        styleClass="shortcut-btn"/>

                <Button text="✏ Modifier"
                        onAction="#handleEditUser"
                        styleClass="shortcut-btn"/>

                <Button text="🗑 Supprimer"
                        onAction="#handleDeleteUser"
                        styleClass="shortcut-btn logout-shortcut"/>

                <Button text="↩ Retour"
                        onAction="#handleBackToAdminDashboard"
                        styleClass="stat-btn"/>
            </HBox>
        </VBox>
    </top>

    <center>
        <VBox spacing="16.0" styleClass="main-area">
            <padding>
                <Insets top="0.0" right="24.0" bottom="24.0" left="24.0"/>
            </padding>

            <VBox spacing="12.0" VBox.vgrow="ALWAYS" styleClass="big-card">
                <Label text="Liste des utilisateurs" styleClass="card-title"/>

                <HBox spacing="10.0" alignment="CENTER_LEFT">
                    <Label text="🔍 Rechercher :" />
                    <TextField fx:id="searchField"
                               promptText="Email, nom, prénom..."
                               onKeyReleased="#handleSearch"
                               styleClass="input-field"/>

                    <Label text="Type :" />
                    <ComboBox fx:id="typeFilterComboBox"
                              onAction="#handleFilter"
                              promptText="Tous"
                              styleClass="input-field"/>

                    <Label text="Statut :" />
                    <ComboBox fx:id="statusFilterComboBox"
                              onAction="#handleFilter"
                              promptText="Tous"
                              styleClass="input-field"/>
                </HBox>

                <TableView fx:id="usersTable" VBox.vgrow="ALWAYS" styleClass="modern-table">
                    <columns>
                        <TableColumn fx:id="emailColumn" text="Email" prefWidth="250.0"/>
                        <TableColumn fx:id="fullNameColumn" text="Nom complet" prefWidth="220.0"/>
                        <TableColumn fx:id="phoneColumn" text="Téléphone" prefWidth="150.0"/>
                        <TableColumn fx:id="typeColumn" text="Type" prefWidth="150.0"/>
                        <TableColumn fx:id="statusColumn" text="Statut" prefWidth="140.0"/>
                        <TableColumn fx:id="createdAtColumn" text="Créé le" prefWidth="180.0"/>
                    </columns>
                </TableView>
            </VBox>
        </VBox>
    </center>

</BorderPane>