<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="org.example.controllers.RegisterController">

    <!-- LEFT IMAGE / MESSAGE -->
    <left>
        <StackPane prefWidth="400" style="-fx-background-color:#e8f5e9;">
            <VBox alignment="CENTER" spacing="15">
                <Label text="🌿" style="-fx-font-size:80px;"/>
                <Label text="Rejoins WasteWise"
                       style="-fx-font-size:22px;-fx-font-weight:bold;"/>
                <Label text="Gagne des EcoPoints ♻️"
                       style="-fx-text-fill:gray;"/>
            </VBox>
        </StackPane>
    </left>

    <!-- RIGHT FORM -->
    <center>
        <ScrollPane fitToWidth="true">
            <VBox spacing="12" alignment="CENTER" style="-fx-padding:30;">

                <Label text="Créer un compte"
                       style="-fx-font-size:26px;-fx-font-weight:bold;"/>

                <Label text="Rejoins WasteWise 🌿"
                       style="-fx-text-fill:gray;"/>

                <!-- NOM + PRENOM -->
                <HBox spacing="10">
                    <TextField fx:id="nomField" promptText="Nom" HBox.hgrow="ALWAYS"/>
                    <TextField fx:id="prenomField" promptText="Prénom" HBox.hgrow="ALWAYS"/>
                </HBox>

                <!-- EMAIL -->
                <TextField fx:id="emailField" promptText="Email"/>

                <!-- PASSWORD -->
                <PasswordField fx:id="passwordField" promptText="Mot de passe"/>
                <PasswordField fx:id="confirmPasswordField" promptText="Confirmer mot de passe"/>

                <!-- TELEPHONE + ROLE -->
                <HBox spacing="10">
                    <TextField fx:id="telephoneField" promptText="Téléphone" HBox.hgrow="ALWAYS"/>

                    <VBox spacing="5">
                        <Label text="Rôle"/>
                        <HBox spacing="10">
                            <RadioButton fx:id="citoyenRadio" text="Citoyen" selected="true">
                                <toggleGroup>
                                    <ToggleGroup fx:id="roleGroup"/>
                                </toggleGroup>
                            </RadioButton>
                            <RadioButton fx:id="valorizerRadio" text="Valorisateur" toggleGroup="$roleGroup"/>
                        </HBox>
                    </VBox>
                </HBox>

                <!-- FACE -->
                <Label text="Face embedding (optionnel)"/>
                <TextArea fx:id="faceEmbeddingArea" prefRowCount="3"/>

                <!-- TERMS -->
                <CheckBox fx:id="agreeTermsCheckBox" text="J'accepte les conditions"/>

                <!-- BUTTON -->
                <Button text="Créer un compte"
                        onAction="#handleRegister"
                        maxWidth="Infinity"
                        style="-fx-background-color:#198754;-fx-text-fill:white;"/>

                <!-- SOCIAL -->
                <Label text="OU s’inscrire avec"/>

                <HBox spacing="10">
                    <Button text="Google"/>
                    <Button text="Facebook"/>
                    <Button text="GitHub"/>
                </HBox>

                <!-- LOGIN LINK -->
                <HBox alignment="CENTER">
                    <Label text="Déjà un compte ? "/>
                    <Hyperlink text="Se connecter"
                               onAction="#handleBackToLogin"/>
                </HBox>

                <Label fx:id="messageLabel"/>

            </VBox>
        </ScrollPane>
    </center>
</BorderPane>