<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="org.example.controllers.ForgotPasswordController"
      alignment="CENTER"
      spacing="15"
      prefWidth="900" prefHeight="600"
      styleClass="right-pane">

    <padding>
        <Insets top="30" right="30" bottom="30" left="30"/>
    </padding>

    <Label text="Mot de passe oublié" styleClass="title-label"/>
    <Label text="Saisis ton email, on t’envoie un lien." styleClass="subtitle-label"/>

    <TextField fx:id="emailField"
               promptText="Votre email"
               maxWidth="350"
               styleClass="input-field"/>

    <Button text="Envoyer le lien"
            onAction="#handleSendLink"
            maxWidth="350"
            styleClass="btn-primary"/>

    <Button text="Ouvrir la page de réinitialisation"
            onAction="#handleOpenResetPage"
            maxWidth="350"
            styleClass="btn-outline"/>

    <Button text="Retour à la connexion"
            onAction="#handleBackToLogin"
            maxWidth="350"
            styleClass="btn-light"/>

    <Label fx:id="messageLabel"
           wrapText="true"
           maxWidth="500"
           styleClass="message-label"/>
</VBox>