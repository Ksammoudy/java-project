<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.VBox?>
<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="org.example.controllers.ForgotPasswordController"
      alignment="CENTER"
      spacing="20"
      prefWidth="900" prefHeight="600"
      styleClass="right-pane"
      stylesheets="@../styles/style.css">

    <VBox spacing="18" maxWidth="420" styleClass="auth-card">
        <padding>
            <Insets top="30" right="30" bottom="30" left="30"/>
        </padding>

        <Label text="Mot de passe oublié" styleClass="title-label"/>
        <Label text="Saisis ton email, on t’envoie un lien."
               wrapText="true"
               styleClass="subtitle-label"/>

        <TextField fx:id="emailField"
                   promptText="Votre email"
                   styleClass="input-field"/>

        <Button text="Envoyer le lien"
                onAction="#handleSendLink"
                maxWidth="Infinity"
                styleClass="btn-success"/>

        <Button text="Ouvrir la page de réinitialisation"
                onAction="#handleOpenResetPage"
                maxWidth="Infinity"
                styleClass="btn-outline"/>

        <Button text="Retour à la connexion"
                onAction="#handleBackToLogin"
                maxWidth="Infinity"
                styleClass="btn-light"/>

        <Label fx:id="messageLabel"
               wrapText="true"
               styleClass="message-label"/>
    </VBox>

</VBox>