<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.chart.BarChart?>
<?import javafx.scene.chart.CategoryAxis?>
<?import javafx.scene.chart.NumberAxis?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Priority?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="org.example.controllers.DashboardValorizerController"
            styleClass="workspace-root">
    <left>
        <VBox prefWidth="276.0" spacing="10.0" styleClass="workspace-sidebar">
            <padding>
                <Insets top="24.0" right="16.0" bottom="16.0" left="16.0"/>
            </padding>
            <VBox spacing="4.0" styleClass="brand-shell">
                <Label text="WasteWise" styleClass="brand-logo-text"/>
            </VBox>
            <Label text="Menu Principal" styleClass="sidebar-section"/>
            <Button text="Accueil" onAction="#handleDashboard" maxWidth="Infinity" styleClass="sidebar-nav active"/>
            <Button text="Dechets recus" onAction="#handleReceivedWaste" maxWidth="Infinity" styleClass="sidebar-nav muted"/>
            <Button text="Valorisation" onAction="#handleValorisation" maxWidth="Infinity" styleClass="sidebar-nav muted"/>
            <Button text="Statistiques" onAction="#handleStats" maxWidth="Infinity" styleClass="sidebar-nav muted"/>
            <Button text="Parametres" onAction="#handleProfile" maxWidth="Infinity" styleClass="sidebar-nav muted"/>
            <Region VBox.vgrow="ALWAYS"/>
            <VBox spacing="2.0" styleClass="sidebar-footer">
                <Label fx:id="valorizerNameLabel" text="Utilisateur Demo" styleClass="user-meta-name"/>
                <Label text="Valorisateur" styleClass="user-meta-role"/>
            </VBox>
        </VBox>
    </left>
    <center>
        <VBox styleClass="workspace-main">
            <HBox spacing="12.0" alignment="CENTER_LEFT" styleClass="workspace-topbar">
                <Button text="Menu" styleClass="crumb-button"/>
                <Label text="Home >" styleClass="crumb-text"/>
                <Label text="Admin &gt;" styleClass="crumb-text"/>
                <Label text="Dashboard" styleClass="crumb-current"/>
                <Region HBox.hgrow="ALWAYS"/>
                <VBox alignment="CENTER_RIGHT" spacing="3.0">
                    <Label fx:id="valorizerHeaderNameLabel" text="Utilisateur Demo" styleClass="workspace-title"/>
                    <Label text="Valorisateur" styleClass="workspace-subtitle-strong"/>
                </VBox>
            </HBox>
            <ScrollPane fitToWidth="true" hbarPolicy="NEVER" styleClass="content-scroll">
                <content>
                    <VBox spacing="18.0" styleClass="workspace-content">
                        <HBox alignment="CENTER_LEFT" styleClass="hero-panel">
                            <VBox spacing="10.0">
                                <Label text="Bienvenue Valorisateur" styleClass="hero-title"/>
                                <Label text="Optimisez la valorisation des dechets collectes pour un futur plus durable." styleClass="hero-subtitle"/>
                            </VBox>
                        </HBox>

                        <VBox spacing="8.0" styleClass="strip-card">
                            <Label text="Meteo actuelle - Tunis" styleClass="weather-title"/>
                            <Label text="17C" styleClass="weather-value"/>
                            <Label text="Vent: 2.8 km/h | Code meteo: 0 | Maj: 2026-02-26T09:45" styleClass="weather-meta"/>
                        </VBox>

                        <HBox spacing="18.0">
                            <VBox HBox.hgrow="ALWAYS" spacing="10.0" styleClass="stat-card">
                                <Label text="Dechets recus" styleClass="stat-title"/>
                                <Label text="540 kg" styleClass="stat-value-large"/>
                            </VBox>
                            <VBox HBox.hgrow="ALWAYS" spacing="10.0" styleClass="stat-card">
                                <Label text="Dechets valorises" styleClass="stat-title"/>
                                <Label text="410 kg" styleClass="stat-value-large"/>
                            </VBox>
                            <VBox HBox.hgrow="ALWAYS" spacing="10.0" styleClass="stat-card">
                                <Label text="En attente" styleClass="stat-title"/>
                                <Label text="130 kg" styleClass="stat-value-large"/>
                            </VBox>
                            <VBox HBox.hgrow="ALWAYS" spacing="10.0" styleClass="stat-card">
                                <Label text="Rendement" styleClass="stat-title"/>
                                <Label text="76%" styleClass="stat-value-large"/>
                            </VBox>
                        </HBox>

                        <HBox spacing="18.0">
                            <VBox HBox.hgrow="ALWAYS" spacing="14.0" styleClass="panel-card">
                                <HBox spacing="10.0" alignment="CENTER_LEFT">
                                <Label text="Valorisation des declarations approuvees" styleClass="panel-heading"/>
                                    <Region HBox.hgrow="ALWAYS"/>
                                    <Button text="Voir les statistiques" onAction="#handleStats" styleClass="outline-btn"/>
                                </HBox>
                                <Label text="Cette section affiche uniquement les declarations deja validees et pretes pour le suivi terrain."
                                       wrapText="true" styleClass="section-subtitle"/>
                                <HBox spacing="12.0">
                                    <Label text="Total valorise: 7" styleClass="hero-pill"/>
                                    <Label text="Total points attribues: 1800" styleClass="hero-pill"/>
                                </HBox>
                                <BarChart fx:id="valorisationChart" legendVisible="false" prefHeight="280.0">
                                    <xAxis>
                                        <CategoryAxis/>
                                    </xAxis>
                                    <yAxis>
                                        <NumberAxis/>
                                    </yAxis>
                                </BarChart>
                            </VBox>
                            <VBox prefWidth="330.0" spacing="14.0" styleClass="action-card">
                                <Label text="Actions rapides" styleClass="panel-heading"/>
                                <Button text="Retour aux dechets recus" onAction="#handleReceivedWaste" maxWidth="Infinity" styleClass="primary-btn"/>
                                <Button text="Voir les statistiques" onAction="#handleStats" maxWidth="Infinity" styleClass="outline-btn"/>
                                <Button text="Parametres" onAction="#handleProfile" maxWidth="Infinity" styleClass="outline-btn"/>
                            </VBox>
                        </HBox>
                    </VBox>
                </content>
            </ScrollPane>
        </VBox>
    </center>
</BorderPane>
