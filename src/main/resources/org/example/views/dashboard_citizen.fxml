<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="org.example.controllers.DashboardCitizenController"
            prefWidth="1200.0" prefHeight="750.0"
            styleClass="citizen-root"
            stylesheets="@../styles/style.css">

    <left>
        <VBox prefWidth="270.0" spacing="14.0" styleClass="citizen-sidebar">
            <padding>
                <Insets top="24.0" right="18.0" bottom="24.0" left="18.0"/>
            </padding>

            <HBox spacing="10.0" styleClass="citizen-brand-box">
                <StackPane styleClass="citizen-logo">
                    <Label text="♻"/>
                </StackPane>

                <VBox spacing="2.0">
                    <Label text="WasteWise" styleClass="citizen-brand-title"/>
                    <Label text="Citizen panel" styleClass="citizen-brand-subtitle"/>
                </VBox>
            </HBox>

            <VBox spacing="8.0" styleClass="citizen-user-box">
                <Label fx:id="headerEmailLabel"
                       text="citizen@email.com"
                       styleClass="citizen-user-email"/>
                <HBox spacing="8.0">
                    <Label text="Citoyen" styleClass="citizen-pill-info"/>
                    <Label fx:id="statusBadgeLabel" text="Actif" styleClass="citizen-pill-warn"/>
                </HBox>
            </VBox>

            <VBox spacing="8.0">
                <Button text="🏠 Dashboard"
                        onAction="#handleDashboard"
                        maxWidth="Infinity"
                        styleClass="citizen-nav-btn active"/>

                <Button text="👤 Mon profil"
                        onAction="#handleProfile"
                        maxWidth="Infinity"
                        styleClass="citizen-nav-btn"/>

                <Button text="✏ Modifier profil"
                        onAction="#handleEditProfile"
                        maxWidth="Infinity"
                        styleClass="citizen-nav-btn"/>

                <Button text="🚪 Déconnexion"
                        onAction="#handleLogout"
                        maxWidth="Infinity"
                        styleClass="citizen-nav-btn danger"/>
            </VBox>

            <Region VBox.vgrow="ALWAYS"/>

            <Label text="WasteWise TN • espace citoyen"
                   wrapText="true"
                   styleClass="citizen-footer"/>
        </VBox>
    </left>

    <center>
        <VBox spacing="20.0" styleClass="citizen-main">
            <padding>
                <Insets top="24.0" right="26.0" bottom="26.0" left="26.0"/>
            </padding>

            <HBox alignment="CENTER_LEFT" spacing="12.0">
                <VBox spacing="4.0">
                    <Label text="Citoyen" styleClass="citizen-h1"/>
                    <Label text="WasteWise TN • Espace citoyen" styleClass="citizen-sub"/>
                </VBox>

                <Region HBox.hgrow="ALWAYS"/>

                <Button text="👤 Mon profil"
                        onAction="#handleProfile"
                        styleClass="citizen-top-btn"/>

                <Button text="✏ Modifier"
                        onAction="#handleEditProfile"
                        styleClass="citizen-top-btn primary"/>
            </HBox>

            <VBox spacing="8.0" styleClass="citizen-card2">
                <Label fx:id="welcomeLabel"
                       text="Bienvenue 👋"
                       styleClass="citizen-card-title"/>
                <Label text="Gestion du compte utilisateur citoyen."
                       wrapText="true"
                       styleClass="citizen-note"/>
            </VBox>

            <HBox spacing="16.0">
                <VBox spacing="8.0" HBox.hgrow="ALWAYS" styleClass="citizen-stat-card">
                    <Label text="Email" styleClass="citizen-stat-label"/>
                    <Label fx:id="emailLabel" text="—" styleClass="citizen-stat-value"/>
                    <Label text="Identifiant de connexion" styleClass="citizen-stat-hint"/>
                </VBox>

                <VBox spacing="8.0" HBox.hgrow="ALWAYS" styleClass="citizen-stat-card">
                    <Label text="Type" styleClass="citizen-stat-label"/>
                    <Label fx:id="typeLabel" text="CITIZEN" styleClass="citizen-stat-value"/>
                    <Label text="Profil actuel" styleClass="citizen-stat-hint"/>
                </VBox>

                <VBox spacing="8.0" HBox.hgrow="ALWAYS" styleClass="citizen-stat-card">
                    <Label text="Statut du compte" styleClass="citizen-stat-label"/>
                    <Label fx:id="statusLabel" text="Actif" styleClass="citizen-stat-value"/>
                    <Label text="Activation du compte" styleClass="citizen-stat-hint"/>
                </VBox>
            </HBox>

            <HBox spacing="16.0">
                <VBox spacing="12.0" HBox.hgrow="ALWAYS" styleClass="citizen-card2">
                    <Label text="📌 Informations du profil" styleClass="citizen-card-title"/>

                    <Label text="Voici les informations principales de votre compte citoyen."
                           wrapText="true"
                           styleClass="citizen-note"/>

                    <VBox spacing="10.0">
                        <VBox spacing="4.0" styleClass="small-box">
                            <Label text="Nom" styleClass="small-box-title"/>
                            <Label fx:id="nomLabel" text="—" styleClass="small-box-text"/>
                        </VBox>

                        <VBox spacing="4.0" styleClass="small-box">
                            <Label text="Prénom" styleClass="small-box-title"/>
                            <Label fx:id="prenomLabel" text="—" styleClass="small-box-text"/>
                        </VBox>

                        <VBox spacing="4.0" styleClass="small-box">
                            <Label text="Téléphone" styleClass="small-box-title"/>
                            <Label fx:id="telephoneLabel" text="—" styleClass="small-box-text"/>
                        </VBox>
                    </VBox>
                </VBox>

                <VBox spacing="12.0" prefWidth="320.0" styleClass="citizen-card2">
                    <Label text="⚡ Raccourcis" styleClass="citizen-card-title"/>

                    <Button text="👤 Voir mon profil"
                            onAction="#handleProfile"
                            maxWidth="Infinity"
                            styleClass="citizen-action-btn"/>

                    <Button text="✏ Modifier mon profil"
                            onAction="#handleEditProfile"
                            maxWidth="Infinity"
                            styleClass="citizen-action-btn"/>

                    <Button text="🚪 Déconnexion"
                            onAction="#handleLogout"
                            maxWidth="Infinity"
                            styleClass="citizen-action-btn"/>

                    <Label text="Ce dashboard est centré sur la gestion du compte utilisateur."
                           wrapText="true"
                           styleClass="citizen-note"/>
                </VBox>
            </HBox>
        </VBox>
    </center>

</BorderPane>