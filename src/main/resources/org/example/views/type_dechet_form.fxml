<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Priority?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="org.example.controllers.TypeDechetFormController"
            styleClass="workspace-root">
    <center>
        <VBox styleClass="workspace-main">
            <HBox spacing="12.0" alignment="CENTER_LEFT" styleClass="workspace-topbar">
                <Button text="Menu" styleClass="crumb-button"/>
                <Label text="Home >" styleClass="crumb-text"/>
                <Label text="Admin >" styleClass="crumb-text"/>
                <Label text="Types de dechets" styleClass="crumb-text"/>
                <Label text="Formulaire" styleClass="crumb-current"/>
            </HBox>
            <ScrollPane fitToWidth="true" hbarPolicy="NEVER" styleClass="content-scroll">
                <content>
                    <VBox spacing="18.0" styleClass="workspace-content">
                        <VBox spacing="10.0" styleClass="hero-panel">
                            <Label fx:id="pageTitleLabel" text="Ajouter un type de dechet" styleClass="hero-title"/>
                            <Label fx:id="pageSubtitleLabel" text="Creez une nouvelle categorie pour les declarations citoyennes." styleClass="hero-subtitle"/>
                        </VBox>

                        <VBox spacing="16.0" styleClass="panel-card">
                            <Label text="Informations du type" styleClass="panel-heading"/>

                            <VBox spacing="8.0">
                                <Label text="Libelle *" styleClass="field-label"/>
                                <TextField fx:id="libelleField" promptText="Ex: Papier / Carton" styleClass="input-field"/>
                            </VBox>

                            <VBox spacing="8.0">
                                <Label text="Points/kg *" styleClass="field-label"/>
                                <TextField fx:id="pointsField" promptText="Ex: 9" styleClass="input-field"/>
                            </VBox>

                            <VBox spacing="8.0">
                                <Label text="Description tri" styleClass="field-label"/>
                                <TextArea fx:id="descriptionField" promptText="Consignes de tri visibles dans les declarations..." prefRowCount="5" wrapText="true" styleClass="text-area"/>
                            </VBox>

                            <Label fx:id="formMessageLabel" text="" wrapText="true"/>

                            <HBox spacing="12.0">
                                <Button text="Enregistrer" onAction="#handleSave" styleClass="primary-btn"/>
                                <Button text="Annuler" onAction="#handleCancel" styleClass="outline-btn"/>
                                <Region HBox.hgrow="ALWAYS"/>
                            </HBox>
                        </VBox>
                    </VBox>
                </content>
            </ScrollPane>
        </VBox>
    </center>
</BorderPane>
