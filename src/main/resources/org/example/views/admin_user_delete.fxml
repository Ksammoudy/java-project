<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="18.0"
      alignment="CENTER_LEFT"
      xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="org.example.controllers.UserController"
      prefWidth="850.0" prefHeight="500.0"
      styleClass="dashboard-root"
      stylesheets="@../styles/style.css">

    <padding>
        <Insets top="24.0" right="24.0" bottom="24.0" left="24.0"/>
    </padding>

    <VBox spacing="4.0">
        <Label text="🗑 Supprimer utilisateur"
               styleClass="page-title"/>
        <Label text="Vous êtes sur le point de supprimer cet utilisateur."
               styleClass="page-subtitle"/>
    </VBox>

    <VBox spacing="10.0" styleClass="big-card">
        <Label text="Confirmation" styleClass="card-title"/>

        <VBox spacing="8.0">
            <VBox spacing="4.0" styleClass="small-box">
                <Label text="Email" styleClass="small-box-title"/>
                <Label fx:id="deleteUserEmailLabel" text="—" styleClass="small-box-text"/>
            </VBox>

            <VBox spacing="4.0" styleClass="small-box">
                <Label text="Nom complet" styleClass="small-box-title"/>
                <Label fx:id="deleteUserNameLabel" text="—" styleClass="small-box-text"/>
            </VBox>
        </VBox>

        <Label fx:id="deleteMessageLabel"
               text=""
               wrapText="true"
               styleClass="message-label"/>

        <HBox spacing="10.0">
            <Button text="Supprimer"
                    onAction="#handleConfirmDelete"
                    styleClass="btn-dark"/>

            <Button text="Annuler"
                    onAction="#handleCancelDelete"
                    styleClass="btn-light"/>
        </HBox>
    </VBox>
</VBox>