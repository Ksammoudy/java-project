<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="16"
      alignment="CENTER_LEFT"
      xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="org.example.controllers.UserController"
      style="-fx-background-color: white;">

    <padding>
        <Insets top="25" right="25" bottom="25" left="25"/>
    </padding>

    <Label text="🗑 Supprimer utilisateur"
           style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #c62828;"/>

    <Label text="Vous êtes sur le point de supprimer cet utilisateur."
           style="-fx-text-fill: #666666;"/>

    <VBox spacing="8"
          style="-fx-background-color: #f8f9fa; -fx-padding: 15; -fx-border-color: #dddddd; -fx-border-radius: 8; -fx-background-radius: 8;">
        <Label text="Email :" style="-fx-font-weight: bold;"/>
        <Label fx:id="deleteUserEmailLabel" text="—"/>

        <Label text="Nom complet :" style="-fx-font-weight: bold;"/>
        <Label fx:id="deleteUserNameLabel" text="—"/>
    </VBox>

    <Label fx:id="deleteMessageLabel"
           text=""
           style="-fx-font-weight: bold;"/>

    <HBox spacing="10">
        <Button text="Supprimer"
                onAction="#handleConfirmDelete"
                style="-fx-background-color: #dc3545; -fx-text-fill: white; -fx-font-weight: bold;"/>

        <Button text="Annuler"
                onAction="#handleCancelDelete"
                style="-fx-background-color: #6c757d; -fx-text-fill: white;"/>
    </HBox>
</VBox>