<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="org.example.controllers.ResetPasswordController"
      alignment="CENTER"
      spacing="20"
      prefWidth="900" prefHeight="600"
      styleClass="right-pane"
      stylesheets="@../styles/style.css">

    <VBox spacing="18" maxWidth="420" styleClass="auth-card">
        <padding>
            <Insets top="30" right="30" bottom="30" left="30"/>
        </padding>

        <Label text="Nouveau mot de passe" styleClass="title-label"/>
        <Label text="Collez le token reçu puis saisissez le nouveau mot de passe."
               wrapText="true"
               styleClass="subtitle-label"/>

        <TextField fx:id="tokenField"
                   promptText="Token de réinitialisation"
                   styleClass="input-field"/>

        <PasswordField fx:id="passwordField"
                       promptText="Nouveau mot de passe"
                       styleClass="input-field"/>

        <PasswordField fx:id="confirmPasswordField"
                       promptText="Confirmer le mot de passe"
                       styleClass="input-field"/>

        <Button text="Mettre à jour"
                onAction="#handleResetPassword"
                maxWidth="Infinity"
                styleClass="btn-success"/>

        <Button text="Retour à la connexion"
                onAction="#handleBackToLogin"
                maxWidth="Infinity"
                styleClass="btn-light"/>

        <Label fx:id="messageLabel"
               wrapText="true"
               styleClass="message-label"/>
    </VBox>

</VBox>