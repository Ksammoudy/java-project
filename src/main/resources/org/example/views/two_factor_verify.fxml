<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="org.example.controllers.TwoFactorVerifyController"
      alignment="CENTER"
      spacing="20"
      style="-fx-background-color: #f6f8fb;">

    <padding>
        <Insets top="30" right="30" bottom="30" left="30"/>
    </padding>

    <!-- Titre -->
    <Label text="🔐 Vérification 2FA"
           style="-fx-font-size: 22px; -fx-font-weight: bold;"/>

    <!-- Description -->
    <Label text="Saisissez le code à 6 chiffres depuis Google Authenticator"
           wrapText="true"
           style="-fx-text-fill: #555; -fx-font-size: 13px;"/>

    <!-- Champ code -->
    <TextField fx:id="codeField"
               promptText="123456"
               maxWidth="200"
               style="-fx-font-size: 18px; -fx-alignment: center;"
    />

    <!-- Message erreur -->
    <Label fx:id="messageLabel"
           textFill="red"
           style="-fx-font-size: 12px;"/>

    <!-- Bouton -->
    <Button text="Vérifier"
            onAction="#handleVerify"
            style="-fx-background-color: #2563eb; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 10 20;"/>

    <!-- Bouton retour -->
    <Button text="Annuler"
            onAction="#handleCancel"
            style="-fx-background-color: #e5e7eb; -fx-text-fill: black; -fx-padding: 8 20;"/>

</VBox>