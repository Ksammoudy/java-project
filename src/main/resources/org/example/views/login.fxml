<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.Hyperlink?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="org.example.controllers.LoginController"
            prefWidth="1100.0" prefHeight="700.0"
            styleClass="root-pane"
            stylesheets="@../styles/style.css">

    <left>
        <StackPane prefWidth="520.0" styleClass="left-pane">
            <VBox alignment="CENTER" spacing="24.0" maxWidth="390.0" styleClass="left-content">

                <HBox alignment="CENTER" spacing="10.0" styleClass="left-badge">
                    <Label text="♻" styleClass="left-badge-icon"/>
                    <Label text="Plateforme écoresponsable" styleClass="left-badge-text"/>
                </HBox>

                <Label text="Bienvenue sur WasteWise TN"
                       wrapText="true"
                       styleClass="left-title"/>

                <Label text="Déclare tes déchets, suis tes contributions et gagne des EcoPoints dans une expérience simple, moderne et intelligente."
                       wrapText="true"
                       styleClass="left-subtitle"/>

                <HBox alignment="CENTER" spacing="18.0">
                    <VBox alignment="CENTER" spacing="6.0" styleClass="info-card">
                        <Label text="24/7" styleClass="info-value"/>
                        <Label text="Accès rapide" styleClass="info-label"/>
                    </VBox>

                    <VBox alignment="CENTER" spacing="6.0" styleClass="info-card">
                        <Label text="+100" styleClass="info-value"/>
                        <Label text="EcoPoints" styleClass="info-label"/>
                    </VBox>

                    <VBox alignment="CENTER" spacing="6.0" styleClass="info-card">
                        <Label text="TN" styleClass="info-value"/>
                        <Label text="Communauté" styleClass="info-label"/>
                    </VBox>
                </HBox>

                <StackPane styleClass="left-visual-box">
                    <Label text="♻" styleClass="left-big-icon"/>
                </StackPane>

            </VBox>
        </StackPane>
    </left>

    <center>
        <StackPane styleClass="right-pane">
            <VBox spacing="18.0" maxWidth="420.0" styleClass="auth-card">
                <padding>
                    <Insets top="35.0" right="35.0" bottom="35.0" left="35.0"/>
                </padding>

                <VBox spacing="8.0" alignment="CENTER">
                    <Label text="Connexion" styleClass="title-label"/>
                    <Label text="Connecte-toi à ton compte" styleClass="subtitle-label"/>
                </VBox>

                <VBox spacing="10.0">
                    <Button text="Continuer avec Google"
                            onAction="#handleGoogleLogin"
                            maxWidth="Infinity"
                            styleClass="btn-light"/>

                    <Button text="Continuer avec Facebook"
                            onAction="#handleFacebookLogin"
                            maxWidth="Infinity"
                            styleClass="btn-primary"/>

                    <Button text="Continuer avec GitHub"
                            onAction="#handleGithubLogin"
                            maxWidth="Infinity"
                            styleClass="btn-dark"/>
                </VBox>

                <HBox alignment="CENTER" spacing="10.0">
                    <Separator HBox.hgrow="ALWAYS"/>
                    <Label text="OU" styleClass="or-label"/>
                    <Separator HBox.hgrow="ALWAYS"/>
                </HBox>

                <VBox spacing="6.0">
                    <Label text="Email" styleClass="field-label"/>
                    <TextField fx:id="emailField"
                               promptText="ex: khalil@email.com"
                               styleClass="input-field"/>
                </VBox>

                <VBox spacing="6.0">
                    <Label text="Mot de passe" styleClass="field-label"/>
                    <PasswordField fx:id="passwordField"
                                   promptText="********"
                                   styleClass="input-field"/>
                </VBox>

                <HBox alignment="CENTER_LEFT" spacing="10.0">
                    <CheckBox fx:id="rememberMeCheckBox" text="Se souvenir de moi"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Hyperlink text="Mot de passe oublié ?"
                               onAction="#handleForgotPassword"
                               styleClass="link-action"/>
                </HBox>

                <Button text="Connexion"
                        onAction="#handleLogin"
                        maxWidth="Infinity"
                        styleClass="btn-success"/>

                <Button text="Connexion avec visage"
                        onAction="#handleFaceLogin"
                        maxWidth="Infinity"
                        styleClass="btn-outline"/>

                <HBox alignment="CENTER" spacing="5.0">
                    <Label text="Pas de compte ?" styleClass="small-muted"/>
                    <Hyperlink text="Créer un compte"
                               onAction="#handleRegister"
                               styleClass="link-action"/>
                </HBox>

                <Label fx:id="messageLabel"
                       text=""
                       wrapText="true"
                       styleClass="message-label"/>
            </VBox>
        </StackPane>
    </center>

</BorderPane>