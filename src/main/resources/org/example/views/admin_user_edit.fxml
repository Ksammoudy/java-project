<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="18.0"
      xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="org.example.controllers.UserController"
      prefWidth="950.0" prefHeight="650.0"
      styleClass="dashboard-root"
      stylesheets="@../styles/style.css">

    <padding>
        <Insets top="24.0" right="24.0" bottom="24.0" left="24.0"/>
    </padding>

    <HBox alignment="CENTER_LEFT" spacing="10.0">
        <VBox spacing="4.0">
            <Label fx:id="formTitleLabel"
                   text="Modifier utilisateur"
                   styleClass="page-title"/>
            <Label text="Mettre à jour les informations du compte"
                   styleClass="page-subtitle"/>
        </VBox>

        <Region HBox.hgrow="ALWAYS"/>
    </HBox>

    <VBox spacing="16.0" styleClass="big-card">
        <Label text="Informations du compte" styleClass="card-title"/>

        <HBox spacing="16.0">
            <VBox spacing="6.0" HBox.hgrow="ALWAYS">
                <Label text="Email" styleClass="field-label"/>
                <TextField fx:id="emailField"
                           promptText="Email"
                           styleClass="input-field"/>
            </VBox>

            <VBox spacing="6.0" HBox.hgrow="ALWAYS">
                <Label text="Téléphone" styleClass="field-label"/>
                <TextField fx:id="telephoneField"
                           promptText="Téléphone"
                           styleClass="input-field"/>
            </VBox>
        </HBox>

        <HBox spacing="16.0">
            <VBox spacing="6.0" HBox.hgrow="ALWAYS">
                <Label text="Nom" styleClass="field-label"/>
                <TextField fx:id="nomField"
                           promptText="Nom"
                           styleClass="input-field"/>
            </VBox>

            <VBox spacing="6.0" HBox.hgrow="ALWAYS">
                <Label text="Prénom" styleClass="field-label"/>
                <TextField fx:id="prenomField"
                           promptText="Prénom"
                           styleClass="input-field"/>
            </VBox>
        </HBox>

        <HBox spacing="16.0">
            <VBox spacing="6.0" HBox.hgrow="ALWAYS">
                <Label text="Type" styleClass="field-label"/>
                <ComboBox fx:id="typeComboBox"
                          promptText="Type"
                          maxWidth="Infinity"
                          styleClass="input-field"/>
            </VBox>

            <VBox spacing="6.0" HBox.hgrow="ALWAYS">
                <Label text="Rôles" styleClass="field-label"/>
                <TextField fx:id="rolesField"
                           promptText="Rôles"
                           styleClass="input-field"/>
            </VBox>
        </HBox>

        <VBox spacing="6.0">
            <Label text="Nouveau mot de passe (optionnel)" styleClass="field-label"/>
            <PasswordField fx:id="passwordField"
                           promptText="Laisser vide pour ne pas changer"
                           styleClass="input-field"/>
        </VBox>

        <HBox spacing="20.0">
            <CheckBox fx:id="activeCheckBox" text="Compte actif"/>
            <CheckBox fx:id="verifiedCheckBox" text="Compte vérifié"/>
        </HBox>

        <Label fx:id="formMessageLabel"
               text=""
               wrapText="true"
               styleClass="message-label"/>

        <HBox spacing="10.0">
            <Button text="✔ Enregistrer les modifications"
                    onAction="#handleSaveUser"
                    styleClass="btn-success"/>

            <Button text="Annuler"
                    onAction="#handleCancelForm"
                    styleClass="btn-light"/>
        </HBox>
    </VBox>
</VBox>