<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="org.example.Controllers.ParticipationController"
      spacing="10">

    <Label text="Participation Page"
           style="-fx-font-size: 18px; -fx-font-weight: bold;" />

    <TableView fx:id="tableParticipation">

        <columns>
            <TableColumn fx:id="colId" text="ID"/>
            <TableColumn fx:id="colDate" text="Date"/>
            <TableColumn fx:id="colEvent" text="Event ID"/>
            <TableColumn fx:id="colCitoyen" text="Citoyen ID"/>
            <TableColumn fx:id="colActions" text="Actions"/>
        </columns>

    </TableView>

</VBox>