<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="10"
      alignment="CENTER"
      xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="org.example.Controllers.AddEvenementController">

    <Label text="Ajouter Evenement" style="-fx-font-size: 18px;" />

    <TextField fx:id="txtTitre" promptText="Titre" />
    <TextField fx:id="txtDescription" promptText="Description" />
    <TextField fx:id="txtLieu" promptText="Lieu" />
    <DatePicker fx:id="datePicker" />

    <Button text="Ajouter"
            onAction="#addEvent"
            style="-fx-background-color: #2ecc71; -fx-text-fill: white;" />

</VBox>