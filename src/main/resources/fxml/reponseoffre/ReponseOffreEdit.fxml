<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane prefHeight="860.0"
            prefWidth="1400.0"
            style="-fx-background-color: linear-gradient(to right, #D8F0E5, #C9ECE8);"
            xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="controllers.reponseoffre.ReponseOffreEditController">

    <top>
        <HBox alignment="CENTER_LEFT"
              spacing="18.0"
              style="-fx-background-color: linear-gradient(to right, #0E223D, #1B2F4D); -fx-padding: 12 20 12 20;">
            <StackPane minHeight="24.0" minWidth="24.0" prefHeight="24.0" prefWidth="24.0"
                       style="-fx-background-color: #22C55E; -fx-background-radius: 999;">
                <Label text="W" style="-fx-text-fill: #0E223D; -fx-font-size: 12px; -fx-font-weight: bold;"/>
            </StackPane>
            <Label text="WasteWise TN" style="-fx-text-fill: #FFFFFF; -fx-font-size: 24px; -fx-font-weight: bold;"/>

            <Region HBox.hgrow="ALWAYS"/>
            <HBox spacing="12.0">
                <Button mnemonicParsing="false" onAction="#onOpenDashboard" text="Accueil"
                        style="-fx-background-color: transparent; -fx-text-fill: #FFFFFF; -fx-font-size: 14px;"/>
                <Button mnemonicParsing="false" onAction="#onOpenAppelOffre" text="Appels d'offre"
                        style="-fx-background-color: transparent; -fx-text-fill: #FFFFFF; -fx-font-size: 14px;"/>
                <Button mnemonicParsing="false" onAction="#onOpenReponseCreate" text="Reponses"
                        style="-fx-background-color: transparent; -fx-text-fill: #22C55E; -fx-font-size: 14px; -fx-font-weight: bold;"/>
                <Button mnemonicParsing="false" onAction="#onOpenReponseList" text="Liste"
                        style="-fx-background-color: transparent; -fx-text-fill: #FFFFFF; -fx-font-size: 14px;"/>
            </HBox>
            <Region HBox.hgrow="ALWAYS"/>
            <Label text="Utilisateur connecte" style="-fx-text-fill: #DCE6F2; -fx-font-size: 13px;"/>
        </HBox>
    </top>

    <center>
        <StackPane BorderPane.alignment="CENTER">
            <padding>
                <Insets top="26.0" right="24.0" bottom="26.0" left="24.0"/>
            </padding>

            <VBox spacing="14.0" maxWidth="1020.0"
                  style="-fx-background-color: #F3F7F4; -fx-background-radius: 20; -fx-padding: 18 18 18 18; -fx-effect: dropshadow(gaussian, rgba(12,31,53,0.14), 22, 0, 0, 7);">

                <VBox spacing="4.0">
                    <Label text="Reponses d'offre > Modification"
                           style="-fx-text-fill: #4C6A5B; -fx-font-size: 12px; -fx-font-weight: bold;"/>
                    <Label text="Modifier la reponse d'offre"
                           style="-fx-text-fill: #0D2B40; -fx-font-size: 34px; -fx-font-weight: bold;"/>
                    <Label text="Mettez a jour la quantite, le message et les liens de la reponse."
                           style="-fx-text-fill: #5E7C6D; -fx-font-size: 14px;"/>
                </VBox>

                <Label fx:id="lblMessage"
                       text="Chargement..."
                       style="-fx-background-color: #EEF7F1; -fx-text-fill: #1D5B41; -fx-font-size: 13px; -fx-font-weight: bold; -fx-background-radius: 10; -fx-padding: 10 12 10 12;"/>

                <VBox spacing="12.0"
                      style="-fx-background-color: #FFFFFF; -fx-border-color: #D6E3DB; -fx-border-radius: 14; -fx-background-radius: 14; -fx-padding: 16 16 16 16;">
                    <GridPane hgap="14.0" vgap="10.0">
                        <columnConstraints>
                            <ColumnConstraints hgrow="ALWAYS" percentWidth="50.0"/>
                            <ColumnConstraints hgrow="ALWAYS" percentWidth="50.0"/>
                        </columnConstraints>

                        <VBox spacing="5.0" GridPane.columnIndex="0" GridPane.rowIndex="0">
                            <Label text="Quantite proposee"
                                   style="-fx-text-fill: #496858; -fx-font-size: 13px; -fx-font-weight: bold;"/>
                            <TextField fx:id="txtQuantiteProposee"
                                       prefHeight="44.0"
                                       style="-fx-background-color: #F7FAF8; -fx-border-color: #C2D6CA; -fx-border-radius: 10; -fx-background-radius: 10; -fx-font-size: 15px;"/>
                            <Label fx:id="lblQuantiteError" managed="false" text="" visible="false"
                                   style="-fx-text-fill: #B91C1C; -fx-font-size: 12px; -fx-font-weight: bold;"/>
                        </VBox>

                        <VBox spacing="5.0" GridPane.columnIndex="1" GridPane.rowIndex="0">
                            <Label text="Message"
                                   style="-fx-text-fill: #496858; -fx-font-size: 13px; -fx-font-weight: bold;"/>
                            <TextArea fx:id="txtMessage"
                                      prefRowCount="3"
                                      wrapText="true"
                                      style="-fx-background-color: #F7FAF8; -fx-border-color: #C2D6CA; -fx-border-radius: 10; -fx-background-radius: 10; -fx-font-size: 14px;"/>
                        </VBox>

                        <VBox spacing="5.0" GridPane.columnIndex="0" GridPane.rowIndex="1">
                            <Label text="Appel d'offre"
                                   style="-fx-text-fill: #496858; -fx-font-size: 13px; -fx-font-weight: bold;"/>
                            <ComboBox fx:id="cbAppelOffre"
                                      prefHeight="44.0"
                                      style="-fx-background-color: #F7FAF8; -fx-border-color: #C2D6CA; -fx-border-radius: 10; -fx-background-radius: 10; -fx-font-size: 14px;"/>
                            <Label fx:id="lblAppelError" managed="false" text="" visible="false"
                                   style="-fx-text-fill: #B91C1C; -fx-font-size: 12px; -fx-font-weight: bold;"/>
                        </VBox>

                        <VBox spacing="5.0" GridPane.columnIndex="1" GridPane.rowIndex="1">
                            <Label text="Citoyen"
                                   style="-fx-text-fill: #496858; -fx-font-size: 13px; -fx-font-weight: bold;"/>
                            <ComboBox fx:id="cbCitoyen"
                                      prefHeight="44.0"
                                      style="-fx-background-color: #F7FAF8; -fx-border-color: #C2D6CA; -fx-border-radius: 10; -fx-background-radius: 10; -fx-font-size: 14px;"/>
                            <Label fx:id="lblCitoyenError" managed="false" text="" visible="false"
                                   style="-fx-text-fill: #B91C1C; -fx-font-size: 12px; -fx-font-weight: bold;"/>
                        </VBox>
                    </GridPane>

                    <HBox spacing="10.0" alignment="CENTER_LEFT">
                        <Button mnemonicParsing="false" onAction="#onMettreAJour" text="Mettre a jour"
                                prefHeight="44.0"
                                style="-fx-background-color: #1E9B63; -fx-text-fill: #FFFFFF; -fx-font-size: 15px; -fx-font-weight: bold; -fx-background-radius: 10; -fx-padding: 8 18 8 18;"/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <Button mnemonicParsing="false" onAction="#onSupprimer" text="Supprimer"
                                prefHeight="44.0"
                                style="-fx-background-color: #DC2626; -fx-text-fill: #FFFFFF; -fx-font-size: 14px; -fx-font-weight: bold; -fx-background-radius: 10; -fx-padding: 8 18 8 18;"/>
                        <Button mnemonicParsing="false" onAction="#onAnnuler" text="Annuler"
                                prefHeight="44.0"
                                style="-fx-background-color: #E4EBE6; -fx-text-fill: #46695B; -fx-font-size: 14px; -fx-font-weight: bold; -fx-background-radius: 10; -fx-padding: 8 18 8 18;"/>
                    </HBox>
                </VBox>
            </VBox>
        </StackPane>
    </center>
</BorderPane>
